# ─────────────────────────────────────────────────────────────
# AI Semiconductor Market Calendar — 환경변수 예시
#
# 이 파일을 .env.local 로 복사해서 사용하세요.
#   cp .env.example .env.local
#
# 아무 값도 채우지 않아도 앱은 "더미 데이터"로 정상 동작합니다.
# Supabase 키를 넣으면 DB 데이터를, API 키를 넣으면 실데이터 동기화를 사용합니다.
# ─────────────────────────────────────────────────────────────

# ── 데이터 소스 선택 ──────────────────────────────────────────
# dummy   : 외부 연동 없이 더미 데이터 사용 (기본값, API 키 불필요)
# supabase: Supabase DB 사용
DATA_SOURCE=dummy

# ── Supabase ────────────────────────────────────────────────
# Supabase 프로젝트 > Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 동기화(쓰기)용. 절대 클라이언트에 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=

# ── 외부 API (선택, 나중에 채우면 자동 활성화) ─────────────────
# https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# https://opendart.fss.or.kr/
OPENDART_API_KEY=

# ── 동기화 보안 ──────────────────────────────────────────────
# /api/sync 호출 시 ?token= 으로 검증. Vercel Cron 보호용.
SYNC_SECRET=change-me
